{
  "name": "lumina-code",
  "displayName": "Lumina Code",
  "description": "A minimal, premium VS Code theme family featuring a curated palette of vibrant lavenders, teals, soft periwinkle grays, and no italics.",
  "version": "1.0.2",
  "license": "MIT",
  "publisher": "Akio333",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Akio333/vscode-lumina-code-theme"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Themes"
  ],
  "scripts": {
    "validate": "node scripts/validate.js",
    "package": "npm run validate && vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.2.1",
    "ovsx": "^0.9.3"
  },
  "contributes": {
    "themes": [
      {
        "label": "Lumina Code (Standard)",
        "uiTheme": "vs-dark",
        "path": "./themes/lumina-code-color-theme.json"
      },
      {
        "label": "Lumina Code (Deep)",
        "uiTheme": "vs-dark",
        "path": "./themes/lumina-code-deep-color-theme.json"
      },
      {
        "label": "Lumina Code (Lighter)",
        "uiTheme": "vs-dark",
        "path": "./themes/lumina-code-lighter-color-theme.json"
      },
      {
        "label": "Lumina Code Light",
        "uiTheme": "vs",
        "path": "./themes/lumina-code-light-color-theme.json"
      }
    ]
  }
}
